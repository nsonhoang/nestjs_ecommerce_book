// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
    moduleFormat = "cjs"

}

datasource db {
  provider = "mysql"

}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  cart      Cart?
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roleId    String
  role      Role    @relation(fields: [roleId], references: [id])
  @@index([roleId]) 
  addresses Address[]
}

model Role {
  id   String @id @default(uuid())
  name String @unique

  users User[]
}

model Category {
  id    String @id @default(uuid())
  name  String @unique

  books BookCategory[]
}
enum BookStatus {
  DRAFT       // Bản nháp (Mặc định khi mới tạo)
  ACTIVE      // Đang hiển thị/đang bán
  HIDDEN      // Tạm ẩn
  ARCHIVED    // Ngừng kinh doanh/Lưu trữ
}

model Book {
  id            String   @id @default(uuid())
  title         String //tên quyển sách
  description   String?  @db.Text
  thumbnail     String

  status      BookStatus @default(DRAFT)
  // price         Decimal  @db.Decimal(10, 2)
  price         Int

  soldCount Int @default(0)//15/4


  categories BookCategory[]

  // Quan hệ khác giữ nguyên
  images        BookImage[]
  inventory     Inventory[]
  // banners       Banner[]
  authors       BookAuthor[]
  // reviews       Review[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  promotions  BookPromotion[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
model BookCategory {
  bookId     String
  categoryId String

  book       Book     @relation(fields: [bookId], references: [id],onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id],onDelete: Cascade)

  @@id([bookId, categoryId]) // khóa chính kép
  @@index([categoryId])

}
model BookImage {
  id      String @id @default(uuid())
  publicId  String @unique
  url     String
  bookId  String
  book    Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
}
model Author {
  id    String @id @default(uuid())
  name  String 
  dateOfBirth DateTime?
  info String? @db.Text
  nationality String?
  // createdAt DateTime @default(now())
  // updatedAt DateTime @updatedAt

  books BookAuthor[]
  @@index([name])
}

model BookAuthor {
  bookId   String
  authorId String

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)//onDelete:Mới thêm 16/4

  @@id([bookId, authorId])
  @@index([authorId])
}

model Address {
  id          String   @id @default(uuid())
  userId      String

  fullName    String
  phone       String

  // Địa chỉ cụ thể (Số nhà, tên đường)
  addressLine String

  // THAY ĐỔI: Sử dụng Foreign Key để liên kết với GHN Master Data
  provinceId      Int      // Tương ứng với Province.id
  districtId  Int      // Tương ứng với District.id
  wardCode    String   // WardCode từ GHN (không lưu Ward master-data trong DB)

  // Quan hệ (Relations)
  province    Province @relation(fields: [provinceId], references: [id])
  district    District @relation(fields: [districtId], references: [id])

  country     String   @default("Vietnam")
  label       String?  // Ví dụ: "Nhà riêng", "Văn phòng"

  isDefault   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

//15/4

model Inventory {
  id        String   @id @default(uuid())
  bookId    String   
  // location  String   // Tên kho (Vd: Kho Quận 1, Kho Quận 7, Kho Long An) bỏ location đi sau có thể update thêm warehouseId để quản lý nhiều kho

  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  quantity  Int      @default(0)

  logs      InventoryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // THAY @unique([bookId]) THÀNH:
  @@unique([bookId]) // Một cuốn sách ở một vị trí cụ thể là duy nhất
  @@index([bookId])
}

model InventoryLog {
  id          String   @id @default(uuid())
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  change      Int
  beforeQty   Int
  afterQty    Int

  type        InventoryLogType
  reason      String?

  createdBy   String? // hoặc relation User

  createdAt   DateTime @default(now())

  @@index([inventoryId])
}

enum InventoryLogType {
  IN
  OUT
  ADJUST
}

// 15/4
model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  items     CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id       String @id @default(uuid())
  cartId   String
  bookId   String

  quantity Int
 

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, bookId])
  @@index([cartId])
}

model Promotion {
  id           String   @id @default(uuid())
  name         String   // Tên chương trình (VD: "Flash Sale 30/4")
  discountRate Int      // Giảm bao nhiêu % (VD: 20)
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  books        BookPromotion[] 
}

// Bảng Trung gian (Pivot Table)
model BookPromotion {
  bookId       String
  promotionId  String

  book         Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  promotion    Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  // Khóa chính kép (Một cuốn sách chỉ được tham gia 1 chương trình đó 1 lần)
  @@id([bookId, promotionId]) 
}

