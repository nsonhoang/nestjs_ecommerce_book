enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNING // trả hàng
  REFUNDED // hoàn tiền
}

enum OrderPaymentMethod {
  COD
  VNPAY
}

model Order {
  id               String            @id @default(uuid())
  code             String            @unique
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status           OrderStatus       @default(PENDING)
  paymentMethod    OrderPaymentMethod
  subtotalAmount   Int
  discountAmount   Int               @default(0)
  shippingFee      Int               @default(0)
  totalAmount      Int
  shippingName     String
  shippingPhone    String
  shippingAddress  String
  shippingWard     String
  // GHN identifiers snapshot (để tạo đơn GHN khi chuyển trạng thái PROCESSING)
  shippingWardCode String?
  shippingDistrict String
  shippingDistrictId Int?
  shippingCity     String
  shippingCountry  String            @default("Vietnam")
  note             String?
      
  shipment         Shipment?        
  items            OrderItem[]
  voucherId        String?           // Mã giảm giá áp dụng cho đơn hàng (nếu có)
  voucher          Voucher?          @relation(fields: [voucherId], references: [id], onDelete: SetNull)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([userId])
  @@unique([userId, voucherId])
}

model OrderItem {
  id             String   @id @default(uuid())
  orderId        String
  bookId         String
  bookTitle      String
  quantity       Int
  unitPrice      Int
  discountAmount Int      @default(0)
  totalAmount    Int

  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  book           Book     @relation(fields: [bookId], references: [id], onDelete: Restrict)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orderId])
  @@index([bookId])
}

model Voucher {
  id              String   @id @default(uuid())
  code            String   @unique // Ví dụ: Giamgia50k, CHAOHE2026
  description     String?
  
  discountType    DiscountType // FIXED_AMOUNT (Trừ tiền thẳng) hoặc PERCENTAGE (% đơn hàng)
  discountValue   Float        // Giá trị giảm (Ví dụ: 50000 hoặc 10)
  
  maxDiscount     Float?       // Giảm tối đa (Dùng khi giảm theo %, ví dụ giảm 10% tối đa 50k)
  minOrderValue   Float    @default(0) // Đơn hàng tối thiểu để áp dụng mã
  
  usageLimit      Int      @default(1) // Tổng số lượt mã này được sử dụng (VD: 100 lượt toàn sàn)
  usedCount       Int      @default(0) // Số lượt đã dùng thực tế
  
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean  @default(true)
  
  // Quan hệ 1-N với Order để biết mã nào đã dùng cho đơn nào
  orders          Order[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt //sau có thể phát thêm voucher
}

enum DiscountType {
  FIXED_AMOUNT
  PERCENTAGE
}

// cái này để quản lý địa chỉ giao hàng, có thể dùng để tích hợp với GHN sau này, hoặc để khách hàng chọn địa chỉ đã lưu khi đặt hàng. Nếu tích hợp GHN thì có thể thêm các trường như provinceId, districtId, wardCode để liên kết với dữ liệu của GHN, giúp tính phí vận chuyển chính xác hơn.
model Province {
  id        Int        @id // ProvinceID từ GHN
  name      String
  // Thêm slug để tìm kiếm không dấu (ví dụ: "ha-noi")
  slug      String?    
  districts District[]
  addresses Address[]

  createdAt DateTime   @default(now())
}

model District {

  id         Int       @id // DistrictID từ GHN
  name       String
  provinceId Int
  province   Province  @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  addresses Address[]

  createdAt DateTime   @default(now())
  
  @@index([provinceId]) // Đánh index để filter huyện theo tỉnh nhanh hơn
}

model Shipment { // cái này tương tác trực tiếp với GHN để quản lý đơn hàng vận chuyển, có thể mở rộng thêm để hỗ trợ nhiều đối tác vận chuyển khác trong tương lai
  id              String   @id @default(uuid())
  orderId         String   @unique // Một đơn hàng thường đi kèm 1 thông tin vận chuyển
  order           Order    @relation(fields: [orderId], references: [id])
  
  // Thông tin từ phía đối tác vận chuyển (GHN)
  ghnOrderCode    String?  @unique // Mã đơn hàng do GHN cấp (Z82BS)
  shippingService String   @default("GHN") 
  
  // Trạng thái vận chuyển (nên đồng bộ với Webhook của GHN)
  status          String   @default("ready_to_pick") 
  
  // Thông tin tài chính thực tế khi giao
  codAmount       Float    // Số tiền thực tế bưu tá cần thu
  shippingFee     Float    // Phí ship thực tế GHN thu của shop
  
  // Thông tin thời gian
  expectedDelivery DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}